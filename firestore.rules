rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDispatcher() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dispatcher';
    }

    function isCitizen() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'citizen';
    }

    // Validate status transitions for emergency alerts
    function isValidStatusTransition(oldStatus, newStatus) {
      // Valid transitions:
      // pending → active (dispatcher accepts)
      // active → arrived (dispatcher arrives)
      // arrived → resolved (dispatcher resolves)
      // Any non-resolved status → cancelled (citizen cancels)
      return (oldStatus == 'pending' && newStatus == 'active') ||
             (oldStatus == 'active' && newStatus == 'arrived') ||
             (oldStatus == 'arrived' && newStatus == 'resolved') ||
             (oldStatus == 'active' && newStatus == 'resolved') ||
             (newStatus == 'cancelled' && oldStatus != 'resolved' && oldStatus != 'cancelled');
    }

    // Users collection - basic profile data
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isOwner(userId);

      // Dispatchers can read citizen profiles
      allow read: if isDispatcher();

      // Medical info subcollection - HIGHLY RESTRICTED
      match /medical_info/{document=**} {
        // Only the owner can read and write their medical info
        allow read, write: if isOwner(userId);

        // NOTE: Dispatchers access medical info through emergency_alerts,
        // not directly from this collection
      }

      // Medical info access log - for audit trail
      match /medical_info_access_log/{logId} {
        // Only the owner can read access logs
        allow read: if isOwner(userId);

        // System can write logs (from service)
        allow write: if isAuthenticated();
      }
    }

    // Emergency alerts collection
    match /emergency_alerts/{alertId} {
      // Citizens can create their own alerts (must start with 'pending' status)
      allow create: if isCitizen() &&
                       request.auth.uid == request.resource.data.userId &&
                       request.resource.data.status == 'pending';

      // Owners can read their own alerts
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Owners can update their own alerts (only to cancel)
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.status == 'cancelled' &&
                       isValidStatusTransition(resource.data.status, request.resource.data.status);

      // Dispatchers can read all alerts
      allow read: if isDispatcher();

      // Dispatchers can update alerts:
      // 1. To accept them (pending → active, when acceptedBy is null/doesn't exist)
      // 2. To mark arrived (active → arrived, only their own accepted alerts)
      // 3. To resolve (arrived/active → resolved, only their own accepted alerts)
      // 4. To update location (only their own accepted alerts, status unchanged)
      allow update: if isDispatcher() && (
        // Accepting an alert (pending → active)
        ((!('acceptedBy' in resource.data) || resource.data.acceptedBy == null) &&
         request.resource.data.status == 'active' &&
         isValidStatusTransition(resource.data.status, request.resource.data.status))
        ||
        // Updating own accepted alert (arrived, resolved, location updates)
        (resource.data.acceptedBy == request.auth.uid &&
         (resource.data.status == request.resource.data.status ||
          isValidStatusTransition(resource.data.status, request.resource.data.status)))
      );

      // Messages subcollection
      match /messages/{messageId} {
        // Participants (citizen or assigned dispatcher) can read messages
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/emergency_alerts/$(alertId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/emergency_alerts/$(alertId)).data.acceptedBy == request.auth.uid
        );

        // Participants can create messages
        allow create: if isAuthenticated() && (
          get(/databases/$(database)/documents/emergency_alerts/$(alertId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/emergency_alerts/$(alertId)).data.acceptedBy == request.auth.uid
        );
      }

      // Calls subcollection
      match /calls/{callId} {
        // Allow reading calls where user is caller or receiver (for collectionGroup queries)
        allow read: if isAuthenticated() && (
          ('callerId' in resource.data && resource.data.callerId == request.auth.uid) ||
          ('receiverId' in resource.data && resource.data.receiverId == request.auth.uid)
        );

        // Participants can create calls (caller must be the creator)
        allow create: if isAuthenticated() &&
          'callerId' in request.resource.data &&
          request.resource.data.callerId == request.auth.uid;

        // Participants can update calls (to accept, reject, or end)
        allow update: if isAuthenticated() && (
          ('callerId' in resource.data && resource.data.callerId == request.auth.uid) ||
          ('receiverId' in resource.data && resource.data.receiverId == request.auth.uid)
        );
      }
    }

    // Facilities collection
    match /facilities/{facilityId} {
      // Everyone can read facilities
      allow read: if isAuthenticated();

      // Only dispatchers can create/update/delete facilities
      allow write: if isDispatcher();
    }

    // Verification codes for 2FA
    match /verificationCodes/{userId} {
      // Users can read and write their own verification codes
      // This is safe because codes are temporary and validated server-side
      allow read, write: if isOwner(userId);
    }

    // Two-factor authentication session tracking
    match /twoFactorSessions/{userId} {
      // Users can read and write their own 2FA session status
      allow read, write: if isOwner(userId);
    }

    // Root-level match for collectionGroup queries on calls
    // This allows querying calls across all emergency alerts
    match /{path=**}/calls/{callId} {
      // Allow reading calls where user is caller or receiver
      allow read: if isAuthenticated() && (
        ('callerId' in resource.data && resource.data.callerId == request.auth.uid) ||
        ('receiverId' in resource.data && resource.data.receiverId == request.auth.uid)
      );
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
