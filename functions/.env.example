# Email service (Resend) - for sending 2FA email codes
# Sign up at: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# SMS service (Twilio) - for sending 2FA SMS codes
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# LiveKit - for generating WebRTC access tokens (SERVER-SIDE ONLY)
# Sign up at: https://cloud.livekit.io/
# IMPORTANT: These are server-side secrets - NEVER expose in client code!
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
